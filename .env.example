VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-with-places

# Web Push (VAPID) — clave pública para el cliente; la privada va en Supabase Edge Function secrets
# Generar par: npm run vapid:generate
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Geográfico — SWITCH GLOBAL (strict | soft | unrestricted)
# Testing masivo: unrestricted. Producción final: strict
VITE_GEO_POLICY=unrestricted

# QA testers (UUIDs o emails separados por coma) — ven shell QA en prod sin ?qa=1
# VITE_QA_TESTER_IDS=uuid-1,tester@example.com
